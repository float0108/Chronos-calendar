{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chronos",
  "version": "0.1.0",
  "identifier": "com.chronos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chronos",
        "width": 380,
        "height": 520,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnBottom": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "center": true,
        "visible": true,
        "shadow": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "plugins": {},
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
